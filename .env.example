# Telegram Bot Token
# Получите у @BotFather в Telegram
TOKEN=your_telegram_bot_token

# PostgreSQL Database URL
# Формат: postgresql+asyncpg://user:password@host:port/database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_bot_db

# AI API Configuration
# API ключ для доступа к AI моделям
IOINTELLIGENCE_API_KEY=your_ai_api_key

# Базовый URL AI API (OpenAI-совместимый endpoint)
AI_BASE_URL=https://api.example.com/v1

# Модель для суммаризации длинных диалогов
SUMMARIZER_MODEL=mistralai/Magistral-Small-2506

# Порог количества символов для запуска суммаризации
# Если история диалога превышает это значение, она будет сжата
SUMMARY_THRESHOLD_CHARS=8000

# Путь к файлу статистики использования моделей
AI_MODEL_USAGE_FILE=ai_model_usage.json

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Путь к файлу логов (оставьте пустым для вывода в консоль)
LOG_FILE=
